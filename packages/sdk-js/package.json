{
  "name": "litert-sdk",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript SDK for LiteRT-Ollama — local HTTP + P2P WebRTC",
  "type": "module",
  "main": "dist/litert-sdk.cjs.js",
  "module": "dist/litert-sdk.esm.js",
  "browser": "dist/litert-sdk.umd.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": ["litert", "ollama", "llm", "webrtc", "p2p", "ai"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafubu/friendly-llm.git"
  },
  "dependencies": {
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "rollup": "^4.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "typescript": "^5.3.0"
  }
}
}
